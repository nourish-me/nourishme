# Cloudflare Worker proxy for the Claude API. The Worker holds the real
# Anthropic key; the app only carries APP_SECRET.
NOURISHME_API_URL=https://your-worker.workers.dev
APP_SECRET=your-shared-secret

# Product analytics (PostHog, EU region). Optional: leave the key empty to
# disable analytics entirely (every capture call becomes a no-op). Create a
# project at eu.posthog.com and paste its Project API key here.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# Legacy direct-to-Anthropic mode, only used when the Worker vars above are
# absent (local dev before the proxy existed).
# ANTHROPIC_API_KEY=sk-ant-xxx
